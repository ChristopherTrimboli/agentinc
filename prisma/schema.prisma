// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id // Privy DID: "did:privy:xxx"
  email     String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Active wallet reference (points to currently selected wallet)
  activeWalletId String?     @unique
  activeWallet   UserWallet? @relation("ActiveWallet", fields: [activeWalletId], references: [id], onDelete: SetNull)

  // Twitter OAuth credentials (encrypted)
  twitterAccessToken       String? @db.Text
  twitterRefreshToken      String? @db.Text
  twitterTokenExpiresAt    DateTime?
  twitterUserId            String? // Twitter user ID
  twitterUsername          String? // Twitter username
  twitterConnectedAt       DateTime? // When user connected Twitter

  // Relations
  agents              Agent[]
  chats               Chat[]
  tasks               AgentTask[]
  resources           Resource[]
  agentChatMessages   AgentChatMessage[] @relation("UserChatMessages")
  stakingPools        StakingPool[]      @relation("UserStakingPools")
  wallets             UserWallet[]       @relation("UserWallets")
  walletTransactions  WalletTransaction[]

  // Marketplace relations
  marketplaceListings  MarketplaceListing[]
  postedTasks          MarketplaceTask[]   @relation("TasksPoster")
  assignedTasks        MarketplaceTask[]   @relation("TasksWorker")
  marketplaceBids      MarketplaceBid[]
  marketplaceReviews       MarketplaceReview[]
  marketplaceReviewsAbout  MarketplaceReview[] @relation("ReviewsAbout")

  @@index([twitterUserId])
  @@index([twitterUsername])
  @@index([activeWalletId])
}

// Multi-wallet support - each user can have multiple Solana wallets
// Server-owned wallets are created via Privy Node SDK with an authorization key as owner.
// The server can sign transactions directly without any client-side signer ceremony.
model UserWallet {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation("UserWallets", fields: [userId], references: [id], onDelete: Cascade)
  privyWalletId   String   // Privy wallet ID (e.g., "wallet_xxx")
  address         String   // Solana wallet address
  serverOwned     Boolean  @default(true)  // True if server owns this wallet (can sign directly)
  label           String?  // Optional user-friendly label
  importedFrom    String?  // Source of wallet (e.g., "bags", "phantom", null for server-created)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Reverse relation for active wallet
  activeForUser User? @relation("ActiveWallet")

  @@unique([userId, address])
  @@index([userId])
  @@index([userId, serverOwned])
  @@index([address])
  @@index([privyWalletId])
}

// Chat session - represents a conversation with an agent
model Chat {
  id        String   @id @default(cuid())
  title     String?  @db.VarChar(100) // Auto-generated from first message or manual
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // User relation
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Agent relation (optional - can chat without specific agent)
  agentId String?
  agent   Agent?  @relation(fields: [agentId], references: [id], onDelete: SetNull)

  // Messages in this chat
  messages ChatMessage[]

  // Tasks originated from this chat
  tasks AgentTask[]

  // Marketplace task linked to this chat
  marketplaceTask MarketplaceTask?

  @@index([userId])
  @@index([agentId])
  @@index([userId, updatedAt])
  @@index([createdAt])
}

// Individual message in a chat
model ChatMessage {
  id        String   @id @default(cuid())
  role      String   // "user" | "assistant" | "system"
  content   String   @db.Text // Message text content
  parts     Json?    // Full message parts (for tool calls, reasoning, etc.)
  createdAt DateTime @default(now())

  // Chat relation
  chatId String
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([chatId, createdAt])
  @@index([chatId, role, createdAt])
  @@index([role])
}

model Agent {
  id           String   @id @default(cuid())
  name         String   @db.VarChar(32) // Token metadata limit
  systemPrompt String   @db.Text
  description  String?  @db.Text
  isPublic     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Creator relation
  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: Cascade)

  // Minted agent fields
  isMinted      Boolean  @default(false)
  imageUrl      String?  // AI-generated profile picture
  bannerUrl     String?  // Optional banner image
  
  // Agent personality (stored as JSON)
  personality       String?  // MBTI type (e.g., "INTJ", "ENTP")
  personalityScores Json?    // Big Five OCEAN scores: { openness, conscientiousness, extraversion, agreeableness, neuroticism }
  
  // Rarity/tier
  rarity        String?  // common, uncommon, rare, epic, legendary
  
  // Enabled toolsets (e.g., "moltbook", "github")
  // Different from 'skills' trait which is conceptual abilities
  enabledSkills String[] @default([])
  
  // Token launch fields (Bags API)
  tokenMint       String?  @unique // Solana token mint address
  tokenSymbol     String?  @db.VarChar(10) // Token symbol (e.g., "$AGNT")
  tokenMetadata   String?  // IPFS metadata URL
  launchWallet    String?  // Wallet that launched the token
  launchSignature String?  // Transaction signature
  launchedAt      DateTime? // When the token was launched

  // ERC-8004 on-chain identity (Solana agent registry)
  erc8004Asset             String?  @unique // Metaplex Core asset pubkey on 8004 registry
  erc8004Uri               String?  // IPFS metadata URI for 8004 registration file
  erc8004CollectionPointer String?  // Collection pointer (c1:bafybeig...)
  erc8004AtomEnabled       Boolean  @default(false) // ATOM reputation engine opt-in
  erc8004RegisteredAt      DateTime? // When the agent was registered on 8004

  // Corporation relation (optional - agent can belong to a corporation)
  corporationId String?
  corporation   Corporation? @relation(fields: [corporationId], references: [id], onDelete: SetNull)

  // Chats with this agent
  chats             Chat[]
  tasks             AgentTask[]
  resources         Resource[]
  agentChatMessages AgentChatMessage[] @relation("AgentChatMessages")
  stakingPool       StakingPool?       @relation("AgentStakingPool")

  // Marketplace relations
  marketplaceListing   MarketplaceListing?
  agentPostedTasks     MarketplaceTask[]   @relation("TasksPosterAgent")
  agentAssignedTasks   MarketplaceTask[]   @relation("TasksWorkerAgent")
  agentBids            MarketplaceBid[]

  // Marketplace spending controls
  marketplaceBudgetSol    Decimal?  @db.Decimal(18, 9) // Max SOL per autonomous hire (null = disabled)
  marketplaceAutoApprove  Boolean  @default(false)

  @@index([createdById])
  @@index([tokenMint])
  @@index([isMinted])
  @@index([isPublic])
  @@index([isPublic, createdAt])
  @@index([corporationId])
  @@index([createdAt])
  @@index([isMinted, launchedAt])
  @@index([createdById, createdAt])
  @@index([isMinted, rarity, createdAt])
  @@index([isMinted, isPublic])
  @@index([erc8004Asset])
}

// Staking pool tracking - links agents to their Streamflow staking pools
model StakingPool {
  id              String   @id @default(cuid())
  agentId         String   @unique // One pool per agent
  agent           Agent    @relation("AgentStakingPool", fields: [agentId], references: [id], onDelete: Cascade)
  tokenMint       String   // The agent's SPL token mint address
  stakePoolAddress String  // Streamflow stake pool PDA address
  rewardPoolNonce Int      @default(0) // Nonce for the reward pool
  rewardMint      String   // Reward token mint (usually same as tokenMint)
  createdById     String   // User who created the pool
  createdBy       User     @relation("UserStakingPools", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())

  @@index([agentId])
  @@index([tokenMint])
  @@index([stakePoolAddress])
  @@index([createdById])
}

model Corporation {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(32)
  description String?  @db.Text
  logo        String?
  color       String?
  size        Int      @default(60)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Token launch fields (Bags API)
  tokenMint       String?   @unique
  tokenSymbol     String?   @db.VarChar(10)
  tokenMetadata   String?
  launchWallet    String?
  launchSignature String?
  launchedAt      DateTime?

  // ERC-8004 on-chain collection
  erc8004CollectionPointer String?
  erc8004CollectionCid     String?

  // Relations
  agents Agent[]

  // Marketplace relations
  marketplaceListing MarketplaceListing?

  @@index([name])
  @@index([tokenMint])
  @@index([createdAt])
}

// Community chat messages per agent (general + VIP in one table)
model AgentChatMessage {
  id            String   @id @default(cuid())
  content       String   @db.VarChar(500)
  walletAddress String   // Sender's Solana wallet address (public ID)
  isVip         Boolean  @default(false) // true = token-gated VIP chat
  createdAt     DateTime @default(now())

  // Agent relation - each agent has its own chat rooms
  agentId String
  agent   Agent  @relation("AgentChatMessages", fields: [agentId], references: [id], onDelete: Cascade)

  // User relation
  userId String
  user   User   @relation("UserChatMessages", fields: [userId], references: [id], onDelete: Cascade)

  @@index([agentId, isVip, createdAt])
  @@index([walletAddress])
  @@index([userId])
  @@index([agentId, createdAt])
}

// Knowledge base resource - source material for RAG
model Resource {
  id        String   @id @default(cuid())
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Owner - each user has their own knowledge per agent
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Optional agent scope - null means global user knowledge
  agentId String?
  agent   Agent?  @relation(fields: [agentId], references: [id], onDelete: SetNull)

  // Embedding chunks
  embeddings Embedding[]

  @@index([userId])
  @@index([agentId])
  @@index([userId, agentId])
  @@index([userId, updatedAt])
  @@index([createdAt])
}

// Vector embedding chunk for similarity search
model Embedding {
  id         String @id @default(cuid())
  content    String @db.Text // The plain text chunk
  // embedding vector(1536) managed via raw SQL (pgvector, text-embedding-3-large with reduced dimensions)

  // Parent resource
  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([resourceId])
}

// ═══════════════════════════════════════════════════════════════════════════
// AGENT TASKS — Durable long-running AI workflows
// ═══════════════════════════════════════════════════════════════════════════

// A recurring or long-running task executed by an AI agent via Vercel Workflow
model AgentTask {
  id          String  @id @default(cuid())
  name        String  @db.VarChar(200)
  description String? @db.Text
  status      String  @default("running") // running, paused, completed, failed, stopped

  // Vercel Workflow integration
  workflowRunId String? @unique

  // Task configuration
  taskPrompt    String @db.Text // The recurring instruction
  intervalMs    Int // Milliseconds between iterations (used by interval + event-or-interval modes)
  maxIterations Int? // Optional cap on iterations

  // Event trigger configuration
  // "interval" = sleep N ms (default), "event" = block on webhook, "event-or-interval" = race
  triggerMode   String  @default("interval")
  // Shared secret callers must include as Bearer token to POST /api/tasks/[id]/trigger
  webhookSecret String? @db.VarChar(128)

  // Tool configuration (same format as chat)
  enabledToolGroups String[]
  enabledSkills     String[]

  // Execution tracking
  currentIteration Int       @default(0)
  lastExecutedAt   DateTime?
  nextExecutionAt  DateTime?
  errorMessage     String?   @db.Text

  // Relations
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentId String
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  chatId  String? // Optional: the chat where the task was created
  chat    Chat?   @relation(fields: [chatId], references: [id], onDelete: SetNull)

  logs TaskLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([agentId])
  @@index([userId, status])
  @@index([workflowRunId])
}

// ═══════════════════════════════════════════════════════════════════════════
// WALLET TRANSACTIONS — Audit log for AI-initiated wallet operations
// ═══════════════════════════════════════════════════════════════════════════

model WalletTransaction {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletAddress String
  type          String   // "sol_transfer" | "token_transfer" | "batch_transfer"
  signature     String?  // Solana tx signature (null if failed)
  status        String   // "success" | "failed"

  // Transfer details
  recipient     String?  // Single recipient address
  recipients    Json?    // Array of { address, amount } for batch transfers
  tokenMint     String?  // Null for SOL transfers
  tokenSymbol   String?
  amount        String   // Lamports or token base units (string for BigInt)
  amountUi      String?  // Human-readable amount (e.g., "1.5 SOL")

  // Context
  agentId       String?  // Which agent initiated the transfer
  chatId        String?  // Which chat conversation
  errorMessage  String?  @db.Text

  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([walletAddress])
  @@index([signature])
  @@index([userId, createdAt])
}

// ═══════════════════════════════════════════════════════════════════════════
// 8004 NETWORK VERIFICATION — Durable verification results (Slop or Not)
// ═══════════════════════════════════════════════════════════════════════════

// Per-agent verification result from the batch cron job
model NetworkVerification {
  id         String   @id @default(cuid())
  asset      String   @unique // 8004 asset pubkey
  status     String   // "verified" | "partial" | "unverified"
  score      Int
  maxScore   Int
  checks     Json     // VerificationCheck[]
  verifiedAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([verifiedAt])
}

// Feedback dedup state — tracks last submitted status and invalid-asset skip list
model NetworkFeedbackState {
  id         String  @id @default(cuid())
  asset      String  @unique // 8004 asset pubkey
  lastStatus String? // last feedback status we submitted on-chain
  skipped    Boolean @default(false) // true = invalid asset, skip future feedback

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([skipped])
}

// Individual iteration log entry for an AgentTask
model TaskLog {
  id        String @id @default(cuid())
  iteration Int
  content   String @db.Text // AI response content
  parts     Json? // Tool calls, reasoning, etc.
  status    String // success, error

  taskId String
  task   AgentTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([taskId])
  @@index([taskId, createdAt])
}

// ═══════════════════════════════════════════════════════════════════════════
// MARKETPLACE — The Hiring Protocol
// ═══════════════════════════════════════════════════════════════════════════

// Supply side: a human, agent, or corporation available for hire
model MarketplaceListing {
  id          String   @id @default(cuid())
  type        String   // "agent" | "human" | "corporation"
  title       String   @db.VarChar(200)
  description String   @db.Text
  category    String   // development, design, research, trading, social_media, irl_task, writing, data, other
  skills      String[] // Tags: ["solana", "rust", "photography", "delivery"]

  // Pricing
  priceType   String   // "hourly" | "fixed" | "per_use" | "bidding"
  priceSol    Decimal? @db.Decimal(18, 9) // SOL amount (null if bidding-only)
  priceToken  String?  // Optional: agent token mint for token payments

  // Location (for IRL tasks)
  location    String?
  isRemote    Boolean  @default(true)

  // Availability
  isAvailable    Boolean  @default(true)
  availableHours Json?    // Schedule object

  // Owner relations (exactly one should be set)
  userId        String?
  user          User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentId       String?      @unique
  agent         Agent?       @relation(fields: [agentId], references: [id], onDelete: Cascade)
  corporationId String?      @unique
  corporation   Corporation? @relation(fields: [corporationId], references: [id], onDelete: Cascade)

  // Aggregate stats (updated on task completion)
  completedTasks Int    @default(0)
  averageRating  Float  @default(0)
  totalRatings   Int    @default(0)
  responseTime   Int?   // Average seconds to respond

  // External agent (alternative to agentId — for open-source / third-party agents)
  externalAgentName  String?  @db.VarChar(200)
  externalAgentImage String?  // Avatar URL
  externalAgentUrl   String?  // REST / HTTP endpoint
  externalMcpUrl     String?  // MCP (Model Context Protocol) endpoint
  externalA2aUrl     String?  // A2A (Agent-to-Agent) protocol endpoint

  // Metadata
  featuredImage String?

  tasks     MarketplaceTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([category])
  @@index([isAvailable])
  @@index([type, category, isAvailable])
  @@index([userId])
  @@index([userId, isAvailable])
  @@index([averageRating])
  @@index([completedTasks])
  @@index([createdAt])
}

// Demand side: a posted task/bounty
model MarketplaceTask {
  id     String @id @default(cuid())
  status String @default("open") // pending_escrow, open, assigned, in_progress, review, completed, disputed, cancelled

  // Task details
  title        String   @db.VarChar(200)
  description  String   @db.Text
  category     String
  requirements String[]

  // Budget (optional fixed SOL bounty on top of task token)
  budgetSol    Decimal  @default(0) @db.Decimal(18, 9)
  budgetToken  String?  // Optional token mint for token payments

  // Featured image (uploaded or AI-generated)
  featuredImage String?

  // Task Token (Bags.fm bonding-curve token minted per task)
  tokenMint           String?  @unique // Bags token mint address
  tokenSymbol         String?  // e.g. "$BUILDSWAP"
  tokenMetadata       String?  // Metadata URL
  tokenLaunchWallet   String?  // Wallet that launched the token
  tokenLaunchSignature String? // Launch tx signature
  tokenConfigKey      String?  // Bags fee-share config key
  tokenFeesClaimed    Decimal  @default(0) @db.Decimal(18, 9) // Total SOL claimed from creator fees

  // Escrow (for optional fixed SOL bounty)
  escrowAmount       Decimal? @db.Decimal(18, 9) // SOL locked in treasury
  escrowTxSignature  String?  // Transfer-in tx
  settleTxSignature  String?  // Release tx
  escrowStatus       String   @default("none") // none, held, released, refunded

  // Milestones (JSON: [{title, amountSol, status}])
  milestones Json?

  // Poster (who created the task)
  posterId      String
  poster        User   @relation("TasksPoster", fields: [posterId], references: [id], onDelete: Restrict)
  posterAgentId String?
  posterAgent   Agent? @relation("TasksPosterAgent", fields: [posterAgentId], references: [id], onDelete: SetNull)

  // Worker (who is assigned)
  workerId      String?
  worker        User?  @relation("TasksWorker", fields: [workerId], references: [id], onDelete: SetNull)
  workerAgentId String?
  workerAgent   Agent? @relation("TasksWorkerAgent", fields: [workerAgentId], references: [id], onDelete: SetNull)

  // Listing (if hired from a listing)
  listingId String?
  listing   MarketplaceListing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  // Delivery
  deliverables  String? @db.Text
  disputeReason String? @db.Text

  // Location
  location String?
  isRemote Boolean @default(true)

  // Timing
  deadline    DateTime?
  completedAt DateTime?

  // Communication
  chatId String? @unique
  chat   Chat?   @relation(fields: [chatId], references: [id], onDelete: SetNull)

  bids    MarketplaceBid[]
  reviews MarketplaceReview[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([category])
  @@index([posterId])
  @@index([workerId])
  @@index([listingId])
  @@index([status, category])
  @@index([posterId, status])
  @@index([workerId, status])
  @@index([posterAgentId])
  @@index([workerAgentId])
  @@index([escrowStatus])
  @@index([deadline])
  @@index([createdAt])
}

// A bid/proposal on a task
model MarketplaceBid {
  id     String @id @default(cuid())
  status String @default("pending") // pending, accepted, rejected, withdrawn

  amountSol     Decimal @db.Decimal(18, 9)
  message       String? @db.Text
  estimatedTime String? // "2 hours", "3 days"

  // Bidder (user or agent)
  bidderId      String
  bidder        User   @relation(fields: [bidderId], references: [id], onDelete: Cascade)
  bidderAgentId String?
  bidderAgent   Agent? @relation(fields: [bidderAgentId], references: [id], onDelete: SetNull)

  taskId String
  task   MarketplaceTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([taskId, bidderId])
  @@index([taskId])
  @@index([bidderId])
  @@index([bidderAgentId])
  @@index([taskId, status])
}

// Post-completion review
model MarketplaceReview {
  id     String @id @default(cuid())
  rating Int    // 1-5
  comment String? @db.Text

  // Who wrote the review
  reviewerId String
  reviewer   User @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  // Who the review is about (poster reviewing worker, or vice versa)
  revieweeId String?
  reviewee   User?  @relation("ReviewsAbout", fields: [revieweeId], references: [id], onDelete: SetNull)

  taskId String
  task   MarketplaceTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([taskId, reviewerId])
  @@index([taskId])
  @@index([reviewerId])
  @@index([revieweeId])
}
