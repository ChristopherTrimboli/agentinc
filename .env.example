# Privy Authentication
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id
PRIVY_APP_SECRET=your_privy_app_secret

# Database (Prisma Postgres)
DATABASE_URL=prisma+postgres://accelerate.prisma-data.net/?api_key=your_prisma_api_key

# AI Gateway
AI_GATEWAY_API_KEY=your_ai_gateway_api_key

# Bags API (Token Launch)
BAGS_API_KEY=your_bags_api_key
BAGS_PARTNER_KEY=your_bags_partner_key
BAGS_PARTNER_WALLET=your_bags_partner_wallet_address

# Vercel Blob Storage
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token

# Solana RPC (server-side)
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key

# Solana RPC (client-side for Privy embedded wallet UI)
NEXT_PUBLIC_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key

OPENAI_API_KEY=your_openai_api_key

TWITTER_CLIENT_ID=your_twitter_client_id
TWITTER_CLIENT_SECRET=your_twitter_client_secret

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+15551234567

# App URL for OAuth callbacks (required for Twitter OAuth)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Encryption key for sensitive data (Twitter tokens stored in DB)
ENCRYPTION_KEY=your_encryption_key_here

# Upstash Redis (for distributed rate limiting, caching, and session management)
# Get these from https://console.upstash.com/redis
KV_REST_API_URL=https://your-redis-instance.upstash.io
KV_REST_API_TOKEN=your_upstash_rest_api_token
KV_REST_API_READ_ONLY_TOKEN=your_upstash_read_only_token
REDIS_URL=rediss://default:your_token@your-instance.upstash.io:6379

# ERC-8004 Agent Registry (Solana)
# Users own their 8004 NFTs via their Privy wallets.
ERC8004_CLUSTER=mainnet-beta
# Optional: group all Agent Inc. agents under one collection for discoverability.
# Run `bun run scripts/setup-8004-collection.ts` to create, then paste the pointer here.
# Requires ERC8004_SIGNER_PRIVATE_KEY (base58 keypair) only during that one-time setup.
# ERC8004_SIGNER_PRIVATE_KEY=your_base58_encoded_secret_key
# ERC8004_COLLECTION_POINTER=your_collection_pointer_after_setup

# IPFS (Pinata) — optional, for IPFS-hosted 8004 metadata. Without it, uses Vercel Blob.
# PINATA_JWT=your_pinata_jwt

# Vercel Cron Secret — protects cron endpoints from unauthorized invocation.
# Vercel sets this automatically on Pro/Enterprise plans.
# CRON_SECRET=your_cron_secret
