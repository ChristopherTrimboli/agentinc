{
  "name": "agentinc",
  "version": "0.1.0",
  "description": "Mint AI agents, form corporations, and launch tokens on Solana",
  "license": "MIT",
  "author": "cjft",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChristopherTrimboli/agentinc.git"
