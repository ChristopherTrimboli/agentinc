  "scripts": {
    "dev": "bun next dev",
    "build": "bun next build",
    "postinstall": "bun prisma generate",
    "start": "bun next start",
    "lint": "bun eslint",
    "format": "bun prettier --write .",
    "db:generate": "bun prisma generate",
    "db:migrate": "bun prisma migrate dev",
    "db:push": "bun prisma db push",
    "db:studio": "bun prisma studio",
    "build:packages": "cd packages/ai-sdk-provider && bun run build",
    "publish:provider": "cd packages/ai-sdk-provider && bun publish --access public"
